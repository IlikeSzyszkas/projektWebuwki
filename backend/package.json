{
  "name": "f1-results-backend",
  "version": "1.0.0",
  "description": "F1 Results Browser - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
